{
  "name": "test-github-app",
  "private": "true",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": "^22.21.0 || >=24.10.0"
  },
  "dependencies": {
    "@azure/monitor-opentelemetry": "^1.16.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.208.0",
    "@opentelemetry/instrumentation-undici": "^0.25.0",
    "octokit": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@octokit/webhooks": "^14.2.0",
    "@tsconfig/node22": "^22.0.5",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.0",
    "globals": "^17.0.0",
    "smee-client": "^5.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "scripts": {
    "lint": "npm run lint:eslint && npm run lint:tsc",
    "lint:eslint": "cross-env DEBUG=eslint:eslint,eslint:linter eslint",
    "lint:tsc": "tsc --build --verbose",
    "start": "node --env-file-if-exists=.env --import @azure/monitor-opentelemetry/loader server.js",
    "smee": "node --env-file-if-exists=.env smee.js"
  }
}
